# ================================================================
# TOSKA DISTRIBUTION — Environment Variables
# Copy this file to .env.local and fill in your values
# ================================================================

# ----------------------------------------------------------------
# DATABASE
# For development (SQLite):
#   DATABASE_URL="file:./dev.db"
# For production (PostgreSQL):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/toska_db?schema=public"
# ----------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# ----------------------------------------------------------------
# AUTH (NextAuth.js)
# Generate a strong secret: openssl rand -base64 32
# ----------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-min-32-chars-change-in-production"
AUTH_SECRET="your-secret-here-min-32-chars-change-in-production"

# ----------------------------------------------------------------
# APP
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TOSKA DISTRIBUTION"

# ----------------------------------------------------------------
# PUSH NOTIFICATIONS (Web Push / VAPID)
# Generate keys: node -e "const wp=require('web-push');console.log(wp.generateVAPIDKeys())"
# ----------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@yourdomain.com"

# ----------------------------------------------------------------
# FILE UPLOADS
# Files are stored locally in /public/uploads/
# For production, consider S3 or similar and update src/app/api/upload/route.ts
# ----------------------------------------------------------------
# UPLOAD_DIR="./public/uploads"  # default, no env needed

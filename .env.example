# ================================================================
# TOSKA DISTRIBUTION — Environment Variables
# Copy this file to .env.local and fill in your values
# ================================================================

# ----------------------------------------------------------------
# DATABASE
# For development (SQLite):
#   DATABASE_URL="file:./dev.db"
# For production (PostgreSQL):
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/toska_db?schema=public"
# ----------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# ----------------------------------------------------------------
# AUTH (NextAuth.js)
# Generate a strong secret: openssl rand -base64 32
# ----------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-min-32-chars-change-in-production"
AUTH_SECRET="your-secret-here-min-32-chars-change-in-production"

# ----------------------------------------------------------------
# APP
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TOSKA DISTRIBUTION"

# ----------------------------------------------------------------
# PUSH NOTIFICATIONS (Web Push / VAPID)
# Generate keys: node -e "const wp=require('web-push');console.log(wp.generateVAPIDKeys())"
# ----------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@yourdomain.com"

# ----------------------------------------------------------------
# SUPABASE STORAGE — required for production file uploads
#
# 1. Go to Supabase dashboard → Storage → Create bucket: product-images
# 2. Set bucket visibility to PUBLIC (so uploaded images are accessible)
# 3. Copy Project URL and Service Role Key from Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL   — Project URL (safe to expose client-side)
# SUPABASE_SERVICE_ROLE_KEY  — Service role secret (server-side only, never expose)
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET — bucket name (default: product-images)
#
# Without these vars the API falls back to local /public/uploads/ (dev only).
# On Vercel the local filesystem is ephemeral — set these vars in Vercel dashboard.
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="product-images"
